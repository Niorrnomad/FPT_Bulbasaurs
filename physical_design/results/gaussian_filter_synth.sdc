set_output_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports {o_data[0]}]
set_input_transition 0.1 [get_ports clk]
set_input_transition 0.1 [get_ports rst_n]
set_input_transition 0.1 [get_ports i_href]
set_input_transition 0.1 [get_ports i_vsync]
