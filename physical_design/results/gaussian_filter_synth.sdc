set_clock_gating_check -setup 0.0 
set_input_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports rst_n]
set_input_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports i_href]
set_input_delay -clock [get_clocks clk] -add_delay -max 1.0 [get_ports i_vsync]
