set sdc_version 2.0

set_units -capacitance 1000fF
set_units -time 1000ps

# Set the current design
current_design gaussian_filter

create_clock -name "clk" -period 4.0 -waveform {0.0 2.0} [get_ports clk]
set_load -pin_load 0.2 [get_ports o_href]
set_load -pin_load 0.2 [get_ports o_vsync]
set_load -pin_load 0.2 [get_ports {o_data[15]}]
set_load -pin_load 0.2 [get_ports {o_data[14]}]
set_load -pin_load 0.2 [get_ports {o_data[13]}]
set_load -pin_load 0.2 [get_ports {o_data[12]}]
